# yc-voice-agent-hackathon - Environment Variables
# Copy this file to .env and fill in your API keys

# Twilio (Transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+13392176343
OPERATOR_PHONE=+13397933010
PUBLIC_TUNNEL_HOST=your-tunnel.example.com

# Gradium (TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# OpenAI (LLM)
OPENAI_API_KEY=

# NVIDIA Nemotron ASR (STT)
NVIDIA_ASR_URL=

# NVIDIA Nemotron LLM
NEMOTRON_LLM_URL=
NEMOTRON_ENABLE_THINKING=